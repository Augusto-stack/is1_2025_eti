<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alumnos - {{materiaNombre}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-2">{{materiaNombre}}</h1>
    <p class="text-gray-500 mb-6">Listado de alumnos inscriptos</p>

    {{#successMessage}}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{{successMessage}}</div>
    {{/successMessage}}
    {{#errorMessage}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{{errorMessage}}</div>
    {{/errorMessage}}

    <div class="bg-white rounded-lg shadow">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b bg-gray-50">
                    <th class="py-3 px-6">Alumno</th>
                    <th class="py-3 px-6">Calificación</th>
                    <th class="py-3 px-6">Acción</th>
                </tr>
            </thead>
            <tbody>
                {{#alumnos}}
                <tr class="border-b hover:bg-gray-50">
                    <td class="py-3 px-6">{{nombre}}</td>
                    <td class="py-3 px-6">{{calificacion}}</td>
                    <td class="py-3 px-6">
                        <form action="/profesor/materias/{{materiaId}}/nota" method="post" class="flex gap-2">
                            <input type="hidden" name="alumnoNombre" value="{{nombre}}">
                            <input type="number" name="nota" min="0" max="10" step="0.5"
                                   placeholder="Nota" required
                                   class="w-24 px-2 py-1 border border-gray-300 rounded text-sm">
                            <button type="submit"
                                    class="bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700 text-sm">
                                Cargar nota
                            </button>
                        </form>
                    </td>
                </tr>
                {{/alumnos}}
                {{^alumnos}}
                <tr>
                    <td colspan="3" class="py-4 px-6 text-center text-gray-400">
                        No hay alumnos inscriptos en esta materia.
                    </td>
                </tr>
                {{/alumnos}}
            </tbody>
        </table>
    </div>

    <div class="text-center mt-6">
        <a href="/profesor/materias" class="text-blue-600 hover:underline">← Volver a mis materias</a>
    </div>
</div>
</body>
</html>