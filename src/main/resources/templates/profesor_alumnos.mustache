<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Alumnos - {{materiaNombre}}</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-2">{{materiaNombre}}</h1>
    <p class="text-gray-500 mb-6">Listado de alumnos inscriptos</p>
    
    {{#successMessage}}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{{successMessage}}</div>
    {{/successMessage}}
    {{#errorMessage}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{{errorMessage}}</div>
    {{/errorMessage}}

    <div class="bg-white rounded-lg shadow">
        <table class="w-full text-left border-collapse">
    <thead>
        <tr class="border-b bg-gray-50">
            <th class="py-3 px-4">Alumno</th>
            <th class="py-3 px-4">Nota 1</th>
            <th class="py-3 px-4">Nota 2</th>
            <th class="py-3 px-4">Promedio</th>
            <th class="py-3 px-4">Cargar notas</th>
        </tr>
    </thead>
    <tbody>
        {{#alumnos}}
        <tr class="border-b hover:bg-gray-50">
            <td class="py-3 px-4 font-medium">{{nombre}}</td>
            <td class="py-3 px-4">{{calificacion1}}</td>
            <td class="py-3 px-4">{{calificacion2}}</td>
            <td class="py-3 px-4">{{promedio}}</td>
            <td class="py-3 px-4">
                <form action="/profesor/materias/{{materiaId}}/nota" method="post" class="flex flex-col gap-2">
                    <input type="hidden" name="alumnoNombre" value="{{nombre}}">
                    <div class="flex gap-2">
                        <input type="number" name="nota1" min="0" max="10" step="0.5"
                               placeholder="Nota 1"
                               class="w-24 px-2 py-1 border border-gray-300 rounded text-sm">
                        <input type="number" name="nota2" min="0" max="10" step="0.5"
                               placeholder="Nota 2"
                               class="w-24 px-2 py-1 border border-gray-300 rounded text-sm">
                        <button type="submit"
                                class="bg-blue-600 text-white px-3 py-1 rounded hover:bg-blue-700 text-sm">
                            Cargar
                        </button>
                    </div>
                    <input type="text" name="comentario" placeholder="Comentario (opcional)"
                           class="px-2 py-1 border border-gray-300 rounded text-sm w-full">
                </form>
            </td>
        </tr>
        {{/alumnos}}
        {{^alumnos}}
        <tr>
            <td colspan="5" class="py-4 px-4 text-center text-gray-400">
                No hay alumnos inscriptos en esta materia.
            </td>
        </tr>
        {{/alumnos}}
    </tbody>
</table>
    </div>

    <div class="text-center mt-6">
        <a href="/profesor/materias" class="text-blue-600 hover:underline">← Volver a mis materias</a>
    </div>
</div>
</body>
</html>