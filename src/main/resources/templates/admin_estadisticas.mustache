<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Estadísticas - Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 p-8">
    <div class="max-w-5xl mx-auto space-y-10">

        <!-- Header -->
        <div class="flex justify-between items-center bg-white p-6 rounded-xl shadow-md border-b-4 border-blue-500">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Estadísticas Generales</h1>
                <p class="text-gray-500 text-sm italic">Resumen del sistema</p>
            </div>
            <a href="/dashboard" class="bg-gray-800 text-white px-5 py-2 rounded-lg hover:bg-black transition font-semibold">
                ← Volver
            </a>
        </div>

        <!-- Tarjetas principales -->
        <section>
            <h2 class="text-xl font-bold text-gray-700 mb-4">Usuarios y Materias</h2>
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-blue-400 text-center">
                    <p class="text-4xl font-black text-blue-600">{{totalAlumnos}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Alumnos</p>
                </div>
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-purple-400 text-center">
                    <p class="text-4xl font-black text-purple-600">{{totalProfesores}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Profesores</p>
                </div>
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-green-400 text-center">
                    <p class="text-4xl font-black text-green-600">{{totalMaterias}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Materias</p>
                </div>
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-yellow-400 text-center">
                    <p class="text-4xl font-black text-yellow-600">{{totalInscripciones}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Inscripciones</p>
                </div>
            </div>
        </section>

        <!-- Quejas -->
        <section>
            <h2 class="text-xl font-bold text-gray-700 mb-4">Estado de Quejas <span class="text-gray-400 font-normal text-base">({{quejasTotal}} en total)</span></h2>
            <div class="grid grid-cols-3 gap-4">
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-orange-400 text-center">
                    <p class="text-4xl font-black text-orange-500">{{quejasPendientes}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Pendientes</p>
                </div>
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-blue-300 text-center">
                    <p class="text-4xl font-black text-blue-400">{{quejasEnRevision}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">En Revisión</p>
                </div>
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-green-400 text-center">
                    <p class="text-4xl font-black text-green-600">{{quejasResueltas}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Resueltas</p>
                </div>
            </div>
        </section>

        <!-- Highlights -->
        <section>
            <h2 class="text-xl font-bold text-gray-700 mb-4">Destacados</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                <!-- Alumnos bloqueados -->
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-red-400 text-center">
                    <p class="text-4xl font-black text-red-500">{{alumnosBloqueados}}</p>
                    <p class="text-gray-500 text-sm mt-1 font-semibold">Alumnos Bloqueados</p>
                </div>

                <!-- Materia con más inscriptos -->
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-indigo-400 text-center">
                    {{#hayTopMateria}}
                        <p class="text-2xl font-black text-indigo-600">{{topMateriaNombre}}</p>
                        <p class="text-gray-400 text-xs mt-1">{{topMateriaCantidad}} inscriptos</p>
                        <p class="text-gray-500 text-sm mt-2 font-semibold">Materia con más inscriptos</p>
                    {{/hayTopMateria}}
                    {{^hayTopMateria}}
                        <p class="text-gray-400 italic text-sm mt-4">Sin datos aún</p>
                        <p class="text-gray-500 text-sm mt-2 font-semibold">Materia más popular</p>
                    {{/hayTopMateria}}
                </div>

                <!-- Alumno con mejor promedio -->
                <div class="bg-white rounded-xl shadow p-5 border-t-4 border-teal-400 text-center">
                    {{#hayTopAlumno}}
                        <p class="text-2xl font-black text-teal-600">{{topAlumnoNombre}}</p>
                        <p class="text-gray-400 text-xs mt-1">Promedio: {{topAlumnoPromedio}}</p>
                        <p class="text-gray-500 text-sm mt-2 font-semibold">Mejor promedio</p>
                    {{/hayTopAlumno}}
                    {{^hayTopAlumno}}
                        <p class="text-gray-400 italic text-sm mt-4">Sin notas cargadas</p>
                        <p class="text-gray-500 text-sm mt-2 font-semibold">Mejor promedio</p>
                    {{/hayTopAlumno}}
                </div>

            </div>
        </section>

    </div>
</body>
</html>