<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mis Materias</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
<div class="max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">Materias Disponibles</h1>

    {{#successMessage}}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{{successMessage}}</div>
    {{/successMessage}}
    {{#errorMessage}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{{errorMessage}}</div>
    {{/errorMessage}}

    <div class="grid grid-cols-1 gap-4">
        {{#materias}}
        <div class="bg-white p-6 rounded-lg shadow flex justify-between items-center">
            <div>
                <h2 class="text-xl font-semibold text-gray-800">{{nombre}}</h2>
                <p class="text-sm text-gray-500">Teórico: {{profesorTeorico}}</p>
                <p class="text-sm text-gray-500">Práctico: {{profesorPractico}}</p>
                <p class="text-sm text-gray-400">Inscriptos: {{cantidadAlumnos}}</p>
            </div>
            <div>
                {{#inscripto}}
                <form action="/alumno/desinscribirse/{{id}}" method="post">
                    <button type="submit"
                            class="bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600 text-sm">
                        Desinscribirse
                    </button>
                </form>
                {{/inscripto}}
                {{^inscripto}}
                <form action="/alumno/inscribirse/{{id}}" method="post">
                    <button type="submit"
                            class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700 text-sm">
                        Inscribirse
                    </button>
                </form>
                {{/inscripto}}
            </div>
        </div>
        {{/materias}}
        {{^materias}}
        <div class="bg-white p-6 rounded-lg shadow text-center text-gray-400">
            No hay materias disponibles todavía.
        </div>
        {{/materias}}
    </div>

    <div class="text-center mt-6">
        <a href="/dashboard" class="text-blue-600 hover:underline">← Volver al dashboard</a>
    </div>
</div>
</body>
</html>