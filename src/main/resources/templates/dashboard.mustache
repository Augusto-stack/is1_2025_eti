<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4 relative">

    <div id="alert-container" class="fixed top-5 left-0 right-0 z-50 flex flex-col items-center pointer-events-none space-y-4">
        {{#message}}
        <div id="success-alert" class="bg-green-500 text-white px-6 py-3 rounded-lg shadow-xl font-bold flex items-center pointer-events-auto transition-opacity duration-500 border-b-4 border-green-700">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
            {{message}}
        </div>
        {{/message}}

        {{#error}}
        <div id="error-alert" class="bg-red-500 text-white px-6 py-3 rounded-lg shadow-xl font-bold flex items-center pointer-events-auto transition-opacity duration-500 border-b-4 border-red-700">
            <svg class="w-6 h-6 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            {{error}}
        </div>
        {{/error}}
    </div>

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-2xl mt-12">
        {{#isAdmin}}
        <span class="absolute top-4 right-4 bg-red-100 text-red-700 text-sm font-semibold px-3 py-1 rounded-full">Admin</span>
        {{/isAdmin}}
        {{#isProfesor}}
        <span class="absolute top-4 right-4 bg-blue-100 text-blue-700 text-sm font-semibold px-3 py-1 rounded-full">Profesor</span>
        {{/isProfesor}}
        {{#isAlumno}}
        <span class="absolute top-4 right-4 bg-green-100 text-green-700 text-sm font-semibold px-3 py-1 rounded-full">Alumno</span>
        {{/isAlumno}}
        
        <h1 class="text-3xl font-bold text-center text-gray-800 mb-6">Panel de Control</h1>

        <p class="text-xl text-center text-gray-700 mb-8">
            ¡Bienvenido/a, <span class="font-semibold text-blue-600">{{username}}</span>!
        </p>

        <div class="grid grid-cols-1 gap-6 mb-8">

            {{#isAdmin}}
            <div class="bg-red-50 border border-red-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-red-700 mb-3">Gestión de Usuarios</h2>
                <p class="text-gray-600 mb-4">Administrá las cuentas del sistema.</p>
                <a href="/admin/usuarios" class="inline-block bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300">Ver Usuarios</a>
            </div>
            <div class="bg-yellow-50 border border-yellow-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-yellow-700 mb-3">Cargar Profesor</h2>
                <p class="text-gray-600 mb-4">Ingresá los datos de un nuevo profesor.</p>
                <a href="/cargarProfesor" class="inline-block bg-yellow-600 text-white py-2 px-4 rounded-md hover:bg-yellow-700 transition duration-300">Añadir</a>
            </div>

            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Gestión de Materias</h2>
                <p class="text-gray-600 mb-4">Creá y administrá las materias del sistema.</p>
                <a href="/admin/materias" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Materias</a>
            </div>
            {{/isAdmin}}

            {{#isProfesor}}
            <div class="bg-blue-50 border border-blue-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-blue-700 mb-3">Mis Materias</h2>
                <p class="text-gray-600 mb-4">Visualizá las materias que tenés asignadas.</p>
                <a href="/profesor/materias" class="inline-block bg-blue-600 text-white py-2 px-4 rounded-md hover:bg-blue-700 transition duration-300">Ver Materias</a>
            </div>
            {{/isProfesor}}

            {{#isAlumno}}
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Mis Materias</h2>
                <p class="text-gray-600 mb-4">Inscribite o revisá tus materias disponibles.</p>
                <a href="/alumno/materias" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Ver Materias</a>
            </div>
            <div class="bg-green-50 border border-green-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-green-700 mb-3">Mis Notas</h2>
                <p class="text-gray-600 mb-4">Consultá tus calificaciones.</p>
                <a href="/alumno/notas" class="inline-block bg-green-600 text-white py-2 px-4 rounded-md hover:bg-green-700 transition duration-300">Ver Notas</a>
            </div>
            <div class="bg-orange-50 border border-orange-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-orange-700 mb-3">Atención al Alumno</h2>
                <p class="text-gray-600 mb-4">¿Tenés algún problema? Podés iniciar un trámite de queja formal.</p>
                <a href="/alumno/queja" class="inline-block bg-orange-600 text-white py-2 px-4 rounded-md hover:bg-orange-700 transition duration-300">Redactar Queja</a>
            </div>
            {{/isAlumno}}

            {{#isAdmin}}
            <div class="bg-red-50 border border-red-200 p-6 rounded-lg text-center shadow-sm">
                <h2 class="text-2xl font-bold text-red-700 mb-3">Centro de Quejas</h2>
                <p class="text-gray-600 mb-4">Revisá y gestioná los reclamos enviados por los alumnos.</p>
                <a href="/admin/quejas" class="inline-block bg-red-600 text-white py-2 px-4 rounded-md hover:bg-red-700 transition duration-300">Gestionar Quejas</a>
            </div>
            {{/isAdmin}}

        </div>

        <div class="text-center mt-6">
            <a href="/logout" class="inline-block bg-gray-600 text-white py-2 px-6 rounded-md hover:bg-gray-700 transition duration-300 text-lg">Cerrar Sesión</a>
        </div>
    </div>

    <script>
        window.onload = function() {
            const alerts = ['success-alert', 'error-alert'];
            alerts.forEach(id => {
                const alertElement = document.getElementById(id);
                if (alertElement) {
                    setTimeout(() => {
                        alertElement.style.opacity = '0';
                        setTimeout(() => alertElement.remove(), 500); // Borra el elemento después del fade
                    }, 3000); // 3 segundos
                }
            });
        };
    </script>
</body>
</html>