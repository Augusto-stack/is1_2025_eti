<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Panel de Usuarios</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen p-6">
<div class="max-w-4xl mx-auto">

    <h1 class="text-3xl font-bold text-gray-800 mb-6">Panel de Administrador</h1>

    {{#successMessage}}
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">{{successMessage}}</div>
    {{/successMessage}}
    {{#errorMessage}}
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">{{errorMessage}}</div>
    {{/errorMessage}}

    <!-- Tabla de usuarios -->
    <div class="bg-white p-6 rounded-lg shadow">
        <h2 class="text-xl font-semibold text-gray-700 mb-4">Lista de Usuarios</h2>
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b bg-gray-50">
                    <th class="py-2 px-4">Nombre</th>
                    <th class="py-2 px-4">Rol</th>
                    <th class="py-2 px-4">Intentos fallidos</th>
                    <th class="py-2 px-4">Estado</th>
                    <th class="py-2 px-4">Acción</th>
                </tr>
            </thead>
            <tbody>
                {{#usuarios}}
                <tr class="border-b hover:bg-gray-50">
                    <td class="py-2 px-4 font-medium text-gray-800">{{nombre}}</td>
                    <td class="py-2 px-4">
                        {{#esAdmin}}
                        <span class="bg-purple-100 text-purple-700 text-xs font-semibold px-2 py-1 rounded-full">Admin</span>
                        {{/esAdmin}}
                        {{#esProfesor}}
                        <span class="bg-blue-100 text-blue-700 text-xs font-semibold px-2 py-1 rounded-full">Profesor</span>
                        {{/esProfesor}}
                        {{#esAlumno}}
                        <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-1 rounded-full">Alumno</span>
                        {{/esAlumno}}
                    </td>
                    <td class="py-2 px-4 text-center">{{intentos}}</td>
                    <td class="py-2 px-4">
                        {{#bloqueado}}
                        <span class="bg-red-100 text-red-700 text-xs font-semibold px-2 py-1 rounded-full">Bloqueado</span>
                        {{/bloqueado}}
                        {{^bloqueado}}
                        <span class="bg-green-100 text-green-700 text-xs font-semibold px-2 py-1 rounded-full">Activo</span>
                        {{/bloqueado}}
                    </td>
                    <td class="py-2 px-4">
                        {{#bloqueado}}
                        <form action="/admin/desbloquear/{{nombre}}" method="post">
                            <button type="submit"
                                    class="bg-blue-500 text-white px-3 py-1 rounded hover:bg-blue-600 text-sm">
                                Desbloquear
                            </button>
                        </form>
                        {{/bloqueado}}
                        {{^bloqueado}}
                        <span class="text-gray-400 text-sm">—</span>
                        {{/bloqueado}}
                    </td>
                </tr>
                {{/usuarios}}
                {{^usuarios}}
                <tr>
                    <td colspan="5" class="py-4 px-4 text-center text-gray-400">No hay usuarios registrados.</td>
                </tr>
                {{/usuarios}}
            </tbody>
        </table>
    </div>

    <div class="text-center mt-6">
        <a href="/dashboard" class="text-blue-600 hover:underline">← Volver al dashboard</a>
    </div>

</div>
</body>
</html>