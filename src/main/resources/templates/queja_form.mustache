<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Enviar Queja - Sistema Educativo</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

    <div class="bg-white p-8 rounded-lg shadow-lg w-full max-w-lg">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-gray-800">Formulario de Queja</h1>
            <p class="text-gray-600 mt-2">Tu opinión nos ayuda a mejorar. Por favor, detallá tu inconveniente.</p>
        </div>

        {{#errorMessage}}
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-4">
            {{errorMessage}}
        </div>
        {{/errorMessage}}

        <form action="/alumno/queja" method="POST" class="space-y-6">
            
            <div>
                <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Asunto / Título corto</label>
                <input type="text" id="title" name="title" required 
                    placeholder="Ej: Problema con el aula virtual"
                    class="w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-orange-500 focus:border-orange-500 outline-none">
            </div>

            <div>
                <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Descripción detallada</label>
                <textarea id="description" name="description" rows="5" required 
                    placeholder="Escribí aquí los detalles de tu queja..."
                    class="w-full px-4 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-orange-500 focus:border-orange-500 outline-none"></textarea>
            </div>

            <div class="flex items-center justify-between pt-4">
                <a href="/dashboard" class="text-gray-500 hover:text-gray-700 font-medium transition duration-200">
                    ← Volver al Panel
                </a>
                <button type="submit" 
                    class="bg-orange-600 text-white font-bold py-2 px-6 rounded-md hover:bg-orange-700 shadow-md transform active:scale-95 transition duration-200">
                    Enviar Queja
                </button>
            </div>
        </form>
    </div>

</body>
</html>